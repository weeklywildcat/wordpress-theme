{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1280px"
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "color": {
      "custom": false,
      "customGradient": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "palette": [
        {
          "name": "Ink",
          "slug": "ink",
          "color": "#111111"
        },
        {
          "name": "Paper",
          "slug": "paper",
          "color": "#fffdf8"
        },
        {
          "name": "Newsprint",
          "slug": "newsprint",
          "color": "#f5f2ea"
        },
        {
          "name": "Line",
          "slug": "line",
          "color": "#d8d2c7"
        },
        {
          "name": "Muted",
          "slug": "muted",
          "color": "#5f5a54"
        },
        {
          "name": "Accent",
          "slug": "accent",
          "color": "#b51f2a"
        },
        {
          "name": "Accent Dark",
          "slug": "accent-dark",
          "color": "#75131c"
        },
        {
          "name": "Section Blue",
          "slug": "section-blue",
          "color": "#1d4f91"
        },
        {
          "name": "Section Green",
          "slug": "section-green",
          "color": "#286b3c"
        },
        {
          "name": "Section Purple",
          "slug": "section-purple",
          "color": "#68418d"
        },
        {
          "name": "Warning",
          "slug": "warning",
          "color": "#ffd54f"
        }
      ]
    },
    "dimensions": {
      "minHeight": true
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        {
          "name": "Soft",
          "slug": "soft",
          "shadow": "0 0.5rem 1.5rem rgb(17 17 17 / 0.08)"
        },
        {
          "name": "Rule",
          "slug": "rule",
          "shadow": "0 1px 0 var(--wp--preset--color--line)"
        }
      ]
    },
    "spacing": {
      "blockGap": true,
      "margin": true,
      "padding": true,
      "units": [
        "px",
        "rem",
        "em",
        "%",
        "vw",
        "vh"
      ],
      "spacingSizes": [
        {
          "name": "2",
          "slug": "20",
          "size": "0.5rem"
        },
        {
          "name": "3",
          "slug": "30",
          "size": "0.75rem"
        },
        {
          "name": "4",
          "slug": "40",
          "size": "1rem"
        },
        {
          "name": "5",
          "slug": "50",
          "size": "1.5rem"
        },
        {
          "name": "6",
          "slug": "60",
          "size": "2rem"
        },
        {
          "name": "7",
          "slug": "70",
          "size": "3rem"
        },
        {
          "name": "8",
          "slug": "80",
          "size": "4rem"
        },
        {
          "name": "9",
          "slug": "90",
          "size": "6rem"
        }
      ]
    },
    "typography": {
      "customFontSize": false,
      "dropCap": true,
      "fluid": true,
      "fontStyle": true,
      "fontWeight": true,
      "letterSpacing": true,
      "lineHeight": true,
      "textDecoration": true,
      "textTransform": true,
      "fontFamilies": [
        {
          "fontFamily": "Georgia, 'Times New Roman', serif",
          "name": "Serif",
          "slug": "serif"
        },
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
          "name": "System Sans",
          "slug": "system-sans"
        },
        {
          "fontFamily": "'Arial Narrow', 'Helvetica Neue Condensed', 'Roboto Condensed', Arial, sans-serif",
          "name": "Condensed Sans",
          "slug": "condensed-sans"
        }
      ],
      "fontSizes": [
        {
          "name": "Extra Small",
          "slug": "x-small",
          "size": "0.75rem"
        },
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem"
        },
        {
          "name": "Normal",
          "slug": "normal",
          "size": "1rem"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "1.125rem"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "clamp(1.35rem, 1.1rem + 0.9vw, 1.875rem)"
        },
        {
          "name": "Extra Large",
          "slug": "x-large",
          "size": "clamp(1.9rem, 1.4rem + 2vw, 3rem)"
        },
        {
          "name": "XX Large",
          "slug": "xx-large",
          "size": "clamp(2.4rem, 1.7rem + 3.2vw, 4.8rem)"
        },
        {
          "name": "Masthead",
          "slug": "masthead",
          "size": "clamp(2.6rem, 9vw, 6rem)"
        }
      ]
    },
    "custom": {
      "linea": {
        "measure": "66ch",
        "hairline": "1px solid var(--wp--preset--color--line)"
      }
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|paper",
      "text": "var:preset|color|ink"
    },
    "spacing": {
      "blockGap": "var:preset|spacing|50"
    },
    "typography": {
      "fontFamily": "var:preset|font-family|system-sans",
      "fontSize": "var:preset|font-size|normal",
      "lineHeight": "1.6"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "0"
        },
        "color": {
          "background": "var:preset|color|accent",
          "text": "var:preset|color|paper"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "right": "1rem",
            "bottom": "0.75rem",
            "left": "1rem"
          }
        },
        "typography": {
          "fontFamily": "var:preset|font-family|condensed-sans",
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "700",
          "letterSpacing": "0.04em",
          "textTransform": "uppercase"
        }
      },
      "caption": {
        "color": {
          "text": "var:preset|color|muted"
        },
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "lineHeight": "1.35"
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var:preset|font-family|serif",
          "fontWeight": "700",
          "lineHeight": "1.08"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var:preset|font-size|xx-large"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var:preset|font-size|x-large"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var:preset|font-size|large"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|ink"
        },
        "typography": {
          "textDecoration": "underline"
        }
      }
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "0"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|condensed-sans",
          "fontWeight": "700",
          "letterSpacing": "0.04em",
          "textTransform": "uppercase"
        }
      },
      "core/navigation": {
        "typography": {
          "fontFamily": "var:preset|font-family|condensed-sans",
          "fontSize": "var:preset|font-size|small",
          "fontWeight": "700",
          "letterSpacing": "0.05em",
          "textTransform": "uppercase"
        }
      },
      "core/post-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|serif",
          "lineHeight": "1.05"
        }
      },
      "core/post-excerpt": {
        "typography": {
          "lineHeight": "1.45"
        }
      },
      "core/post-terms": {
        "typography": {
          "fontFamily": "var:preset|font-family|condensed-sans",
          "fontSize": "var:preset|font-size|x-small",
          "fontWeight": "700",
          "letterSpacing": "0.06em",
          "textTransform": "uppercase"
        }
      },
      "core/pullquote": {
        "border": {
          "color": "var:preset|color|accent",
          "style": "solid",
          "width": "0 0 0 4px"
        },
        "spacing": {
          "padding": {
            "left": "var:preset|spacing|50"
          }
        },
        "typography": {
          "fontFamily": "var:preset|font-family|serif",
          "fontSize": "var:preset|font-size|large",
          "lineHeight": "1.25"
        }
      },
      "core/quote": {
        "border": {
          "color": "var:preset|color|line",
          "style": "solid",
          "width": "0 0 0 3px"
        },
        "spacing": {
          "padding": {
            "left": "var:preset|spacing|40"
          }
        }
      },
      "core/query-pagination": {
        "typography": {
          "fontFamily": "var:preset|font-family|condensed-sans",
          "fontWeight": "700"
        }
      },
      "core/search": {
        "typography": {
          "fontFamily": "var:preset|font-family|system-sans"
        }
      },
      "core/separator": {
        "color": {
          "background": "var:preset|color|line"
        }
      },
      "core/table": {
        "typography": {
          "fontSize": "var:preset|font-size|small",
          "lineHeight": "1.45"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    },
    {
      "name": "comments",
      "title": "Comments",
      "area": "uncategorized"
    }
  ]
}
